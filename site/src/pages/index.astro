---
const base = import.meta.env.BASE_URL;              // "/mac-sysdash" (no trailing slash)
const asset = (p: string) => `${base.replace(/\/$/, '')}/${p.replace(/^\//, '')}`;
const demoUrl = asset('demo/');                     // interactive build; the copy is demo-forced, no ?demo needed
const pageUrl = 'https://berkayturanci.github.io/mac-sysdash/';
const ogImage = pageUrl + 'hero.png';
const title = 'mac-sysdash — a tiny Mac + GitHub runner dashboard';
const description =
  'A tiny, dependency-light system + GitHub Actions self-hosted runner dashboard for macOS. ' +
  'One Python file, one HTML file. No cloud, no accounts, no token. Viewable over LAN or Tailscale.';

const author = { '@type': 'Person', name: 'Berkay Turancı', url: 'https://github.com/berkayturanci' };
const jsonLd = {
  '@context': 'https://schema.org',
  '@graph': [
    {
      '@type': 'SoftwareApplication',
      '@id': pageUrl + '#app',
      name: 'mac-sysdash',
      description,
      url: pageUrl,
      image: ogImage,
      applicationCategory: 'DeveloperApplication',
      operatingSystem: 'macOS',
      softwareVersion: '1.34.1',
      softwareRequirements: 'Python 3.9+, psutil',
      license: 'https://commonsclause.com/',
      isAccessibleForFree: true,
      offers: { '@type': 'Offer', price: '0', priceCurrency: 'USD' },
      author,
      publisher: author,
      codeRepository: 'https://github.com/berkayturanci/mac-sysdash',
      keywords: 'macOS, dashboard, monitoring, GitHub Actions, self-hosted runner, Tailscale, psutil, launchd',
    },
    {
      '@type': 'WebSite',
      '@id': pageUrl + '#website',
      name: 'mac-sysdash',
      description,
      url: pageUrl,
      inLanguage: 'en',
      publisher: author,
    },
  ],
};

const features = [
  { ic: '📊', h: 'Live gauges & sparklines', p: 'CPU, memory, and disk ring gauges refreshing every second, with ~5 minutes of per-second history and a per-core view.' },
  { ic: '🏃', h: 'Self-hosted runner status', p: "Busy / idle / offline per runner, with the live job's PR, branch, commit, and actor — read from local files, never the GitHub API." },
  { ic: '🖧', h: 'Multi-machine fleet', p: "Point one Mac at the others over LAN or Tailscale and see the whole fleet on one screen. Machines that can't accept inbound can push instead." },
  { ic: '💾', h: 'Accurate disk & memory', p: 'Disk matches the macOS Storage figure (purgeable-inclusive); memory matches Activity Monitor. Plus a disk-fill ETA.' },
  { ic: '📈', h: 'CI health & history', p: 'Per-runner 30-day health heatmap, flaky-job detection, queue-pressure, and a Gantt timeline — backed by a local SQLite DB.' },
  { ic: '🔔', h: 'Alerts & dead-man checks', p: 'Threshold alerts, offline-runner mutes, a snooze/maintenance mode, an optional webhook, and cron dead-man checks.' },
  { ic: '🎨', h: 'TV mode & themes', p: 'Light / dark / night themes, a wall-mounted TV mode, widget pinning, EN/TR — and a demo mode with no backend.' },
  { ic: '🤖', h: 'AI Copilot quota', p: 'Track your Claude and Codex usage — session and weekly quota bars with reset countdowns and a used/left toggle, read locally with no API keys.' },
  { ic: '🔗', h: 'SSH & screen-share', p: 'Every machine header carries >_ ssh:// and 🖥 vnc:// shortcuts with a copy button — jump onto any Mac in the fleet in a click.' },
  { ic: '🌡', h: 'Thermal & self-update', p: 'A 🌡 chip shows only when the CPU is throttled, and a badge flags when you are commits behind origin/main. Per-app process rollup, too.' },
  { ic: '🪶', h: 'Featherweight', p: 'Runs as a launchd agent without Full Disk Access. Stdlib + psutil on the server, zero JS dependencies on the client — and an installable offline PWA.' },
];
---
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>{title}</title>
  <meta name="description" content={description} />
  <meta name="robots" content="index, follow, max-image-preview:large, max-snippet:-1, max-video-preview:-1" />
  <link rel="canonical" href={pageUrl} />
  <link rel="sitemap" type="application/xml" href={asset('sitemap-index.xml')} />
  <link rel="icon" type="image/svg+xml" href={asset('favicon.svg')} />
  <meta name="theme-color" content="#0a0e14" />
  <meta name="color-scheme" content="dark light" />
  <meta name="application-name" content="mac-sysdash" />
  <meta name="author" content="Berkay Turancı" />
  <meta name="keywords" content="macOS, dashboard, monitoring, GitHub Actions, self-hosted runner, Tailscale, psutil, launchd, system monitor" />

  <meta property="og:type" content="website" />
  <meta property="og:site_name" content="mac-sysdash" />
  <meta property="og:title" content={title} />
  <meta property="og:description" content={description} />
  <meta property="og:url" content={pageUrl} />
  <meta property="og:locale" content="en_US" />
  <meta property="og:image" content={ogImage} />
  <meta property="og:image:type" content="image/png" />
  <meta property="og:image:width" content="2960" />
  <meta property="og:image:height" content="1720" />
  <meta property="og:image:alt" content="The mac-sysdash dashboard: CPU, memory and disk ring gauges, self-hosted GitHub Actions runner status, and a system detail panel." />

  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:title" content={title} />
  <meta name="twitter:description" content={description} />
  <meta name="twitter:image" content={ogImage} />
  <meta name="twitter:image:alt" content="The mac-sysdash dashboard: ring gauges, self-hosted runner status, and a system detail panel." />

  <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
</head>
<body>
<nav>
  <div class="wrap nav-in">
    <a class="brand" href="#top">
      <svg class="logo" viewBox="0 0 32 32" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
        <defs><linearGradient id="lg" x1="0" y1="0" x2="1" y2="1">
          <stop offset="0" stop-color="#4f8cff"/><stop offset="1" stop-color="#9b5cff"/>
        </linearGradient></defs>
        <rect width="32" height="32" rx="7" fill="url(#lg)"/>
        <polyline points="4,20 10,20 13,8 17,24 20,13 28,13" fill="none"
          stroke="#fff" stroke-width="2.8" stroke-linecap="round" stroke-linejoin="round"/>
      </svg>
      mac-sysdash
    </a>
    <div class="nav-links">
      <a href="#features" class="hidephone">Features</a>
      <a href="#how" class="hidephone">How it works</a>
      <a href="#start">Quick start</a>
      <a href="#privacy" class="hidephone">Privacy</a>
      <a class="nav-cta" href="https://github.com/berkayturanci/mac-sysdash">GitHub ↗</a>
    </div>
  </div>
</nav>

<a id="top"></a>
<header class="hero wrap">
  <div class="badges">
    <span class="badge">🖥 <b>macOS</b></span>
    <span class="badge">🐍 <b>Python 3.9+</b></span>
    <span class="badge">📦 one dep: <b>psutil</b></span>
    <span class="badge">⚖️ <b>free, not for resale</b></span>
    <span class="badge">☁️ <b>no cloud</b></span>
  </div>
  <h1>Your Macs &amp; runners,<br>on one quiet dashboard.</h1>
  <p class="lead">
    A tiny system <b>+ GitHub Actions self-hosted runner</b> dashboard for macOS.
    One Python file, one HTML file — <b>no build step, no accounts, no token,
    no cloud.</b> Several Macs show each other's stats over your LAN or Tailscale.
  </p>
  <div class="cta">
    <a class="btn primary" href={demoUrl}>▶ Try the live demo</a>
    <a class="btn ghost" href="#start">Quick start</a>
    <a class="btn ghost" href="https://github.com/berkayturanci/mac-sysdash">GitHub ↗</a>
  </div>
  <div class="demonote">Runs entirely in your browser with sample data — no install, no backend.</div>

  <svg class="pulse" viewBox="0 0 520 60" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
    <defs><linearGradient id="pg" x1="0" y1="0" x2="1" y2="0">
      <stop offset="0" stop-color="#4f8cff"/><stop offset="1" stop-color="#9b5cff"/>
    </linearGradient></defs>
    <path d="M0,30 L150,30 L172,30 L188,10 L206,50 L224,20 L240,30 L300,30 L322,30 L338,14 L354,46 L370,30 L520,30"/>
  </svg>
</header>

<div class="wrap">
  <div class="shot">
    <a href={demoUrl} title="Open the interactive demo">
      <img src={asset('hero.png')} width="2960" height="1720"
        alt="mac-sysdash dashboard: CPU / memory / disk ring gauges, self-hosted runner status with branch and PR, and a system detail panel" loading="eager" />
    </a>
    <div class="cap">The whole thing — ring gauges, live runner status, and system detail in a single page. <a href={demoUrl}>Try it live →</a></div>
  </div>
</div>

<section id="features">
  <div class="wrap">
    <div class="sec-head">
      <div class="kicker">What you get</div>
      <h2>Everything native, nothing bloated</h2>
      <p>Hand-drawn SVG charts, a background sampler, and a stdlib HTTP server. That's it.</p>
    </div>
    <div class="grid">
      {features.map((f) => (
        <div class="card"><div class="ic">{f.ic}</div><h3>{f.h}</h3><p>{f.p}</p></div>
      ))}
    </div>
  </div>
</section>

<section id="how">
  <div class="wrap">
    <div class="how">
      <div>
        <h2>How it works</h2>
        <ul>
          <li>Each Mac runs <b>one Python file</b> that samples the system in the background and serves a JSON API + a single static page.</li>
          <li>The browser opens that page and draws everything with <b>hand-drawn SVG</b> — no framework, no build step.</li>
          <li>Designate one Mac as the <b>hub</b>; it pulls each peer's stats server-side (or peers <b>push</b> to it), so your browser makes no cross-origin calls.</li>
          <li>Reach it over your <b>LAN or Tailscale</b> from any device — phone, tablet, or a TV on the wall.</li>
        </ul>
      </div>
      <svg viewBox="0 0 360 240" xmlns="http://www.w3.org/2000/svg" aria-hidden="true" style="width:100%;height:auto">
        <defs><linearGradient id="ng" x1="0" y1="0" x2="1" y2="1">
          <stop offset="0" stop-color="#4f8cff"/><stop offset="1" stop-color="#9b5cff"/></linearGradient></defs>
        <g stroke="#2d3a4f" stroke-width="2" stroke-dasharray="4 4" fill="none">
          <path d="M80,72 C150,72 150,120 180,120"/>
          <path d="M80,168 C150,168 150,120 180,120"/>
          <path d="M180,120 L270,120"/>
        </g>
        <g font-family="ui-monospace,Menlo,monospace" font-size="11" fill="#8493a8" text-anchor="middle">
          <rect x="20" y="52" width="60" height="40" rx="8" fill="#131822" stroke="#222b3a"/>
          <text x="50" y="76">Mac A</text>
          <rect x="20" y="148" width="60" height="40" rx="8" fill="#131822" stroke="#222b3a"/>
          <text x="50" y="172">Mac B</text>
          <rect x="150" y="98" width="60" height="44" rx="9" fill="#131822" stroke="url(#ng)" stroke-width="2"/>
          <text x="180" y="118" fill="#ccd6e2">hub</text>
          <text x="180" y="131" font-size="9">:8765</text>
          <rect x="270" y="96" width="72" height="48" rx="9" fill="#131822" stroke="#222b3a"/>
          <text x="306" y="116" fill="#ccd6e2">browser</text>
          <text x="306" y="130" font-size="9">phone · TV</text>
        </g>
        <text x="130" y="210" font-family="ui-monospace,Menlo,monospace" font-size="9.5" fill="#56627a" text-anchor="middle">LAN / Tailscale</text>
      </svg>
    </div>
  </div>
</section>

<section id="start">
  <div class="wrap">
    <div class="sec-head">
      <div class="kicker">Quick start</div>
      <h2>Up in about a minute</h2>
      <p>Two ways to run it — a one-command launchd agent, or a manual venv you drive yourself. Both need only Python 3 and <code>psutil</code>.</p>
    </div>
    <div class="methods">
      <div class="method">
        <div class="mhead"><h3>One command</h3><span class="mtag">recommended</span></div>
        <p><code>install.sh</code> sets up an isolated venv and a per-user <b>launchd agent</b> that runs in place from the clone and restarts on login.</p>
        <pre><button class="copy" data-copy={`git clone https://github.com/berkayturanci/mac-sysdash.git\ncd mac-sysdash\n./install.sh`}>Copy</button><code><span class="tok-c"># clone + install (venv + launchd agent)</span>
git clone https://github.com/berkayturanci/mac-sysdash.git
<span class="tok-k">cd</span> mac-sysdash
./install.sh</code></pre>
      </div>
      <div class="method">
        <div class="mhead"><h3>Run it yourself</h3><span class="mtag alt">no agent</span></div>
        <p>Prefer to drive it from your shell? Make a venv and run <code>server.py</code> directly. <kbd>Ctrl-C</kbd> to stop; pick any free port with <code>SYSDASH_PORT</code>.</p>
        <pre><button class="copy" data-copy={`git clone https://github.com/berkayturanci/mac-sysdash.git\ncd mac-sysdash\npython3 -m venv venv && ./venv/bin/pip install psutil\n./venv/bin/python server.py`}>Copy</button><code><span class="tok-c"># clone + run the server directly</span>
git clone https://github.com/berkayturanci/mac-sysdash.git
<span class="tok-k">cd</span> mac-sysdash
python3 -m venv venv &amp;&amp; ./venv/bin/pip install psutil
./venv/bin/python server.py            <span class="tok-c"># serves on :8765</span>
<span class="tok-c"># …or a custom port:</span>
SYSDASH_PORT=8799 ./venv/bin/python server.py</code></pre>
      </div>
    </div>
    <p class="startnote">
      Then open <code>http://localhost:8765</code>. Want a clean HTTPS URL on your
      tailnet (and browser notifications)? Run <code>./serve.sh</code> — it exposes
      it via <a href="https://tailscale.com/">Tailscale</a> Serve. Run the same on
      each Mac and use <b>＋ machine</b> in the header to watch the whole fleet.
    </p>
    <p style="text-align:center;margin-top:26px">
      <a class="btn primary" href={demoUrl}>▶ Try the live demo</a>
      <a class="btn ghost" href="https://github.com/berkayturanci/mac-sysdash#readme">Read the full README →</a>
    </p>
  </div>
</section>

<section id="privacy">
  <div class="wrap">
    <div class="privacy">
      <div class="big">It sends nothing to anyone.</div>
      <p>No telemetry, no analytics, no accounts, no phone-home. Everything stays on
        your own machines and your own network. The only traffic is between the Macs
        you connect yourself.</p>
      <div class="chips">
        <span class="chip"><span class="dot">✓</span> No accounts</span>
        <span class="chip"><span class="dot">✓</span> No third parties</span>
        <span class="chip"><span class="dot">✓</span> No GitHub token</span>
        <span class="chip"><span class="dot">✓</span> Local SQLite only</span>
        <span class="chip"><span class="dot">✓</span> Free to use (even at work) · just don't sell it</span>
      </div>
      <p style="margin-top:22px"><a href="https://github.com/berkayturanci/mac-sysdash/blob/main/PRIVACY.md">Privacy details</a>
        &nbsp;·&nbsp; <a href="https://github.com/berkayturanci/mac-sysdash/blob/main/SECURITY.md">Security &amp; threat model</a></p>
    </div>
  </div>
</section>

<footer>
  <div class="wrap foot">
    <div class="cols">
      <a href="https://github.com/berkayturanci/mac-sysdash">GitHub</a>
      <a href="https://github.com/berkayturanci/mac-sysdash#readme">README</a>
      <a href="https://github.com/berkayturanci/mac-sysdash/blob/main/CHANGELOG.md">Changelog</a>
      <a href="https://github.com/berkayturanci/mac-sysdash/blob/main/CONTRIBUTING.md">Contributing</a>
      <a href="https://github.com/berkayturanci/mac-sysdash/blob/main/PRIVACY.md">Privacy</a>
      <a href="https://github.com/berkayturanci/mac-sysdash/blob/main/SECURITY.md">Security</a>
      <a href="https://github.com/berkayturanci/mac-sysdash/blob/main/LICENSE">License</a>
    </div>
    <div class="made">Built by <a href="https://github.com/berkayturanci">Berkay Turancı</a> · <a href="https://github.com/berkayturanci/mac-sysdash/blob/main/LICENSE">MIT + Commons Clause</a></div>
  </div>
  <div class="wrap tm">
    macOS is a trademark of Apple Inc. · GitHub and GitHub Actions are trademarks
    of GitHub, Inc. · Tailscale is a trademark of Tailscale Inc. · Python is a
    trademark of the Python Software Foundation · Claude is a trademark of
    Anthropic · Codex is a trademark of OpenAI. All other product names are
    trademarks of their respective owners. <b>mac-sysdash is an independent
    project</b> and is not affiliated with, endorsed by, or sponsored by any of them.
  </div>
</footer>

<script>
  document.querySelectorAll('.copy').forEach((b) => {
    b.addEventListener('click', () => {
      const t = b.getAttribute('data-copy') || '';
      navigator.clipboard.writeText(t).then(() => {
        const o = b.textContent;
        b.textContent = 'Copied!';
        setTimeout(() => { b.textContent = o; }, 1400);
      });
    });
  });
</script>

<style is:global>
  :root{
    --bg:#0a0e14; --panel:#131822; --panel2:#1a212e; --line:#222b3a;
    --txt:#ccd6e2; --muted:#8493a8; --accent:#4f8cff; --accent2:#9b5cff;
    --green:#2ecc71; --amber:#f5a623; --red:#ff5c5c;
    --bggrad:radial-gradient(1200px 700px at 80% -10%,#16203a 0%,#0a0e14 55%);
    --mono:ui-monospace,SFMono-Regular,Menlo,Consolas,monospace;
    --sans:-apple-system,BlinkMacSystemFont,"Segoe UI",Roboto,Helvetica,Arial,sans-serif;
  }
  *{box-sizing:border-box}
  html{scroll-behavior:smooth}
  body{margin:0;background:var(--bg);color:var(--txt);
    font-family:var(--sans);line-height:1.6;-webkit-font-smoothing:antialiased;}
  body::before{content:"";position:fixed;inset:0;z-index:-1;background:var(--bggrad)}
  a{color:var(--accent);text-decoration:none}
  a:hover{text-decoration:underline}
  .wrap{max-width:1080px;margin:0 auto;padding:0 22px}
  h1,h2,h3{line-height:1.15;letter-spacing:-.02em;margin:0}

  nav{position:sticky;top:0;z-index:20;backdrop-filter:blur(10px);
    background:rgba(10,14,20,.72);border-bottom:1px solid var(--line)}
  .nav-in{display:flex;align-items:center;gap:18px;height:60px}
  .brand{display:flex;align-items:center;gap:10px;font-weight:700;color:var(--txt);white-space:nowrap}
  .brand:hover{text-decoration:none}
  .logo{width:28px;height:28px;border-radius:7px;display:block}
  .nav-links{margin-left:auto;display:flex;gap:22px;align-items:center}
  .nav-links a{color:var(--muted);font-size:14px;font-weight:500}
  .nav-links a:hover{color:var(--txt);text-decoration:none}
  .nav-cta{padding:7px 14px;border-radius:9px;background:var(--panel2);
    border:1px solid var(--line);color:var(--txt)!important}
  .nav-cta:hover{border-color:var(--accent)}
  @media(max-width:620px){.nav-links .hidephone{display:none}}

  .hero{text-align:center;padding:76px 0 34px}
  .badges{display:flex;gap:8px;justify-content:center;flex-wrap:wrap;margin-bottom:22px}
  .badge{font-size:12px;color:var(--muted);border:1px solid var(--line);
    background:var(--panel);border-radius:999px;padding:4px 11px;font-weight:500}
  .badge b{color:var(--txt)}
  .hero h1{font-size:clamp(34px,6vw,60px);font-weight:800;
    background:linear-gradient(120deg,#eaf1fb 0%,#a8c4ff 60%,#c9a6ff 100%);
    -webkit-background-clip:text;background-clip:text;color:transparent}
  .hero p.lead{max-width:640px;margin:20px auto 0;font-size:clamp(16px,2.3vw,19px);color:var(--muted)}
  .hero p.lead b{color:var(--txt);font-weight:600}
  .cta{display:flex;gap:12px;justify-content:center;flex-wrap:wrap;margin-top:30px}
  .btn{display:inline-flex;align-items:center;gap:8px;padding:12px 20px;border-radius:11px;
    font-weight:600;font-size:15px;border:1px solid transparent;cursor:pointer;
    transition:transform .15s ease,filter .15s ease,border-color .15s ease}
  .btn.primary{background:linear-gradient(120deg,var(--accent),var(--accent2));color:#fff;
    box-shadow:0 8px 26px rgba(79,140,255,.38)}
  .btn.primary:hover{text-decoration:none;filter:brightness(1.06);transform:translateY(-1px)}
  .btn.ghost{background:var(--panel);border-color:var(--line);color:var(--txt)}
  .btn.ghost:hover{text-decoration:none;border-color:var(--accent)}

  .pulse{max-width:520px;margin:34px auto 0;display:block;opacity:.9}
  .pulse path{stroke:url(#pg);stroke-width:2.4;fill:none;stroke-linecap:round;stroke-linejoin:round;
    stroke-dasharray:600;stroke-dashoffset:600;animation:draw 2.6s ease forwards .3s}
  @keyframes draw{to{stroke-dashoffset:0}}

  .shot{margin:46px auto 0;max-width:960px}
  .shot img{width:100%;height:auto;display:block;border-radius:14px;
    border:1px solid var(--line);box-shadow:0 30px 80px rgba(0,0,0,.55)}
  .shot .cap{text-align:center;color:var(--muted);font-size:13px;margin-top:12px}

  section{padding:64px 0}
  .sec-head{text-align:center;max-width:640px;margin:0 auto 42px}
  .sec-head .kicker{color:var(--accent);font-weight:700;font-size:13px;
    text-transform:uppercase;letter-spacing:.12em}
  .sec-head h2{font-size:clamp(26px,4vw,38px);margin-top:10px;font-weight:800}
  .sec-head p{color:var(--muted);margin-top:14px;font-size:16px}

  .grid{display:grid;grid-template-columns:repeat(3,1fr);gap:16px}
  @media(max-width:860px){.grid{grid-template-columns:repeat(2,1fr)}}
  @media(max-width:560px){.grid{grid-template-columns:1fr}}
  .card{background:var(--panel);border:1px solid var(--line);border-radius:14px;padding:22px;
    transition:transform .18s ease,border-color .18s ease}
  .card:hover{transform:translateY(-3px);border-color:#2d3a4f}
  .card .ic{width:38px;height:38px;border-radius:10px;display:grid;place-items:center;
    font-size:20px;background:var(--panel2);border:1px solid var(--line);margin-bottom:14px}
  .card h3{font-size:16.5px;font-weight:700}
  .card p{color:var(--muted);font-size:14px;margin:8px 0 0}

  .how{background:var(--panel);border:1px solid var(--line);border-radius:16px;padding:34px;
    display:grid;grid-template-columns:1.05fr .95fr;gap:34px;align-items:center}
  @media(max-width:820px){.how{grid-template-columns:1fr;gap:24px}}
  .how h2{font-size:28px;font-weight:800}
  .how ul{list-style:none;padding:0;margin:18px 0 0}
  .how li{position:relative;padding-left:26px;margin:12px 0;color:var(--muted);font-size:15px}
  .how li b{color:var(--txt);font-weight:600}
  .how li::before{content:"";position:absolute;left:0;top:9px;width:9px;height:9px;border-radius:50%;
    background:var(--accent);box-shadow:0 0 0 4px rgba(79,140,255,.16)}

  .methods{display:grid;grid-template-columns:1fr 1fr;gap:16px;max-width:900px;margin:0 auto}
  @media(max-width:760px){.methods{grid-template-columns:1fr}}
  .method{background:var(--panel);border:1px solid var(--line);border-radius:14px;padding:20px}
  .method .mhead{display:flex;align-items:center;gap:10px;margin-bottom:6px}
  .method h3{font-size:17px;font-weight:700}
  .mtag{font-size:10.5px;text-transform:uppercase;letter-spacing:.06em;font-weight:700;
    color:#aee9c8;background:rgba(46,204,113,.14);border:1px solid rgba(46,204,113,.4);
    border-radius:999px;padding:2px 8px}
  .mtag.alt{color:#bcd3ff;background:rgba(79,140,255,.14);border-color:rgba(79,140,255,.4)}
  .method p{color:var(--muted);font-size:13.5px;margin:0}
  .method kbd{font-family:var(--mono);font-size:12px;background:var(--panel2);
    border:1px solid var(--line);border-radius:5px;padding:1px 5px;color:var(--txt)}
  .startnote{max-width:820px;margin:24px auto 0;text-align:center;color:var(--muted);font-size:14px}
  .demonote{color:var(--muted);font-size:12.5px;margin-top:12px}
  .shot a{display:block;border-radius:14px;transition:transform .18s ease,box-shadow .18s ease}
  .shot a:hover{transform:translateY(-2px)}
  pre{background:#070a10;border:1px solid var(--line);border-radius:12px;padding:16px 18px;
    overflow-x:auto;margin:12px 0 0;position:relative}
  code{font-family:var(--mono);font-size:13.5px}
  pre code{color:#c8d4e6}
  .tok-c{color:var(--muted)}
  .tok-k{color:#7fd0ff}
  .copy{position:absolute;top:9px;right:9px;background:var(--panel2);border:1px solid var(--line);
    color:var(--muted);font-size:11px;padding:4px 9px;border-radius:7px;cursor:pointer;font-family:var(--sans)}
  .copy:hover{color:var(--txt);border-color:var(--accent)}

  .privacy{text-align:center;background:linear-gradient(180deg,rgba(79,140,255,.06),transparent);
    border:1px solid var(--line);border-radius:16px;padding:42px 26px}
  .privacy .big{font-size:clamp(22px,3.4vw,30px);font-weight:800;
    background:linear-gradient(120deg,#eaf1fb,#a8c4ff);-webkit-background-clip:text;background-clip:text;color:transparent}
  .privacy p{color:var(--muted);max-width:560px;margin:14px auto 0}
  .chips{display:flex;gap:8px;justify-content:center;flex-wrap:wrap;margin-top:22px}
  .chip{font-size:13px;color:var(--txt);background:var(--panel);border:1px solid var(--line);
    border-radius:999px;padding:6px 13px}
  .chip .dot{color:var(--green);font-weight:700}

  footer{border-top:1px solid var(--line);margin-top:40px;padding:40px 0 56px}
  .foot{display:flex;flex-wrap:wrap;gap:20px 34px;align-items:center;justify-content:space-between}
  .foot .cols{display:flex;flex-wrap:wrap;gap:10px 24px}
  .foot a{color:var(--muted);font-size:14px}
  .foot a:hover{color:var(--txt);text-decoration:none}
  .foot .made{color:var(--muted);font-size:13px}
  .foot .made a{color:var(--accent)}
  .tm{margin-top:22px;padding-top:18px;border-top:1px solid var(--line);
    color:var(--muted);font-size:11.5px;line-height:1.7;opacity:.85}
  .tm b{color:var(--txt);font-weight:600}
</style>
</body>
</html>
