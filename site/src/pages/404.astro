---
const base = import.meta.env.BASE_URL;
const home = base.replace(/\/$/, '') + '/';
---
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>404 — mac-sysdash</title>
  <meta name="robots" content="noindex, follow" />
  <meta name="theme-color" content="#0a0e14" />
  <link rel="icon" type="image/svg+xml" href={base.replace(/\/$/, '') + '/favicon.svg'} />
  <style>
    :root{--bg:#0a0e14;--txt:#ccd6e2;--muted:#8493a8;--accent:#4f8cff;--accent2:#9b5cff;--line:#222b3a;--panel:#131822}
    *{box-sizing:border-box}
    body{margin:0;min-height:100vh;display:grid;place-items:center;text-align:center;padding:24px;
      background:#0a0e14;background:radial-gradient(1200px 700px at 80% -10%,#16203a 0%,#0a0e14 55%);
      color:var(--txt);font-family:-apple-system,BlinkMacSystemFont,"Segoe UI",Roboto,Helvetica,Arial,sans-serif}
    .code{font-size:clamp(64px,16vw,140px);font-weight:800;letter-spacing:-.04em;line-height:1;
      background:linear-gradient(120deg,#eaf1fb,#a8c4ff 60%,#c9a6ff);-webkit-background-clip:text;background-clip:text;color:transparent}
    h1{font-size:22px;font-weight:700;margin:14px 0 6px}
    p{color:var(--muted);margin:0 0 26px;max-width:440px}
    a.btn{display:inline-flex;align-items:center;gap:8px;padding:12px 22px;border-radius:11px;font-weight:600;
      color:#fff;text-decoration:none;background:linear-gradient(120deg,var(--accent),var(--accent2));box-shadow:0 8px 26px rgba(79,140,255,.38)}
    a.btn:hover{filter:brightness(1.06)}
    .alt{margin-top:16px;font-size:14px}
    .alt a{color:var(--accent);text-decoration:none}
    svg{width:44px;height:44px;margin-bottom:18px}
  </style>
  <script is:inline defer src="https://static.cloudflareinsights.com/beacon.min.js" data-cf-beacon='{"token": "f9a978b9ccc64ff49460fbcee8f722ef"}'></script>
</head>
<body>
  <main>
    <svg viewBox="0 0 32 32" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
      <defs><linearGradient id="g" x1="0" y1="0" x2="1" y2="1">
        <stop offset="0" stop-color="#4f8cff"/><stop offset="1" stop-color="#9b5cff"/></linearGradient></defs>
      <rect width="32" height="32" rx="7" fill="url(#g)"/>
      <polyline points="4,20 10,20 13,8 17,24 20,13 28,13" fill="none" stroke="#fff" stroke-width="2.8" stroke-linecap="round" stroke-linejoin="round"/>
    </svg>
    <div class="code">404</div>
    <h1>This page went offline.</h1>
    <p>The page you're looking for isn't here — it may have moved, or never existed.</p>
    <a class="btn" href={home}>← Back to mac-sysdash</a>
    <div class="alt"><a href="https://github.com/berkayturanci/mac-sysdash">View on GitHub ↗</a></div>
  </main>
</body>
</html>
